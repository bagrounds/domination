{
  "name": "purescript-wip",
  "version": "0.1.0",
  "description": "purescript work in progress",
  "source": [
    "dist/app.js",
    "assets/stylesheet.css"
  ],
  "scripts": {
    "clean": "rm -rf node_modules .cache dist public .parcel-cache",
    "prebuild": "stylelint assets/*.css",
    "build": "spago build",
    "build-watch": "spago build --watch",
    "bundle": "spago bundle-app --main Main --to dist/app.js",
    "deploy": "./scripts/deploy",
    "serve": "npx node-static -p 8080 public -a",
    "hot-reload": "./scripts/hot-reload",
    "ai-header-comments": "./scripts/ai-header-comments",
    "docs": "spago docs",
    "run": "spago run",
    "test": "spago test",
    "minify-js": "parcel build dist/app.js",
    "minify-css": "parcel build dist/stylesheet.css"
  },
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "hash-function": "^0.1.5",
    "parcel": "^2.0.0-beta.2",
    "purescript": "^0.14.1",
    "spago": "^0.15.3",
    "stylelint": "^13.10.0",
    "stylelint-config-standard": "^20.0.0"
  }
}