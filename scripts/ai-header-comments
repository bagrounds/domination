#!/bin/bash

# Automatically generates module documentation for PureScript files using AI
#
# This script:
# - Recursively finds all .purs files in the src directory
# - Uses Ollama API to generate concise, high-level summaries of each module
# - Preserves existing code while replacing/adding module headers
# - Formats summaries as PureScript module comments {-| ... -}
# - Reports processing time for each file and total runtime
#
# Requirements:
# - Ollama running locally with access to specified model
# - jq for JSON processing
# - curl for API requests
#
# TODO:
# - clean up & refactor
# - improve and persist logging
# - add error handling
# - make the LLM endpoint configurable

set -eu
#MODEL='phi4:14b'
#MODEL='codellama:7b'
MODEL='llama3.2:3b'
#MODEL='llama3.2:1b'

generate_comment() (
    file="$1"
    file_content="$(cat "$file")"
    
    stripped_content=$(echo "$file_content" | sed '/^{-/,/-}/{/-}/d;d};/^--/d')
    
    request='Write a brief, high-level, jargon-free summary of the following module and its purpose. Do not include trivial or obvious details. Be concise and efficient with language. You do not need to use complete sentences. Use short lines and a bulleted list format. Write in the 3rd person and do not name the subject (e.g. "does x" is better than "the module does x"). Only write the result; nothing else. Do not lie - only write what you are sure of.'
    prompt="${request}\n\n${file_content}"
    data=$(jq -n --arg p "$prompt" '{"model": "'"$MODEL"'", "prompt": $p, "stream": false}')
    comment=$(curl -s http://localhost:11434/api/generate -d "$data" | jq -r '.response' | sed 's/^[[:space:]]*//;s/[[:space:]]*$//' | tr -s '\n')
    cat > "$file" << EOF
{-| AI Summary generated by Ollama (${MODEL})
${comment}
-}
${stripped_content}
EOF
)

# Store files in array
mapfile -d $'\0' files < <(find src -name "*.purs" -print0)

script_start=$(date +%s)

# Process each file
for file in "${files[@]}"; do
    echo "Processing '$file'"
    start_time=$(date +%s)
    # Generate comment for the file
    generate_comment "$file"
    end_time=$(date +%s)
    duration=$((end_time - start_time))
    readable_duration=$(date -u -d "@${duration}" +"%H:%M:%S")
    printf "Completed in %s\n\n" "$readable_duration"
done

script_end=$(date +%s)
total_duration=$((script_end - script_start))
readable_total_duration=$(date -u -d "@${total_duration}" +"%H:%M:%S")
echo "Finished processing ${#files[@]} PureScript files in ${readable_total_duration}"
