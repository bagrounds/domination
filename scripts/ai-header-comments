#!/bin/bash

# Automatically generates module documentation for PureScript files using AI
#
# This script:
# - Recursively finds all .purs files in the src directory
# - Uses Ollama API to generate concise, high-level summaries of each module
# - Preserves existing code while replacing/adding module headers
# - Formats summaries as PureScript module comments {-| ... -}
# - Reports processing time for each file and total runtime
#
# Requirements:
# - Ollama running locally with access to specified model
# - jq for JSON processing
# - curl for API requests
#
# TODO:
# - clean up & refactor
# - improve and persist logging
# - add error handling
# - make the LLM endpoint configurable

set -eu
#MODEL='phi4:14b'
#MODEL='codellama:7b'
MODEL='llama3.2:3b'
#MODEL='llama3.2:1b'
#MODEL='qwen2.5-coder:0.5b'

# Add color variables at the top
: "${COLOR_HEADER:=\033[1;34m}"  # Bold blue
: "${COLOR_PROMPT:=\033[0;36m}"  # Cyan
: "${COLOR_RESPONSE:=\033[0;37m}" # Light gray
: "${COLOR_TIME:=\033[0;32m}"    # Green
: "${COLOR_RESET:=\033[0m}"      # Reset

printf "${COLOR_HEADER}[%s] Using model: %s${COLOR_RESET}\n" "$(date '+%Y-%m-%d %H:%M:%S')" "$MODEL" >&2

: "${LLM_API_URL:=http://localhost:11434}"
: "${FILE_PATTERN:=*.purs}"

# Helper function to time operations and report results
time_operation() {
    description="$1"
    shift
    
    start_time=$(date +%s)
    result=$("$@")
    end_time=$(date +%s)
    
    duration=$((end_time - start_time))
    readable_duration=$(date -u -d "@${duration}" +"%H:%M:%S")
    printf "${COLOR_TIME}[%s] completed in %s${COLOR_RESET}\n" "$(date '+%Y-%m-%d %H:%M:%S')" "$readable_duration" >&2
    
    echo "$result"
}

generate_comment() (
    file="$1"
    file_content="$(cat "$file")"
    # Update stripping pattern to handle single-line doc comments
    stripped_content=$(echo "$file_content" | sed '/^{-/,/-}/{/-}/d;d};/^--/d')
    
    # Get responses for each section
    description_prompt="Summarize this PureScript module in 1 line. Use natural language only; no code or markdown. Be direct and concise. Don't use complete sentences; just get to the point."
    concepts_prompt="List the 1-3 most important high-level concepts necessary to understand this module. Use markdown bullet points. Be direct and concise. Don't explain what you're about to say, just say it."

    description=$(query_ollama "$description_prompt" "$stripped_content")
    concepts=$(query_ollama "$concepts_prompt" "$stripped_content")

    # Generate documentation using single-line comments
    cat > "$file" << EOF
--| ## AI Generated Module Summary (${MODEL})
--|
--| ### Description
${description}
--|
--| ### Key Concepts
${concepts}
${stripped_content}
EOF
)

# Helper function to query Ollama
query_ollama() (
    prompt="$1"
    context="$2"
    
    printf "\n${COLOR_PROMPT}%s${COLOR_RESET}\n" "$prompt" >&2
    printf "%s\n" "----------------------------------------" >&2
    
    full_prompt="${prompt}\n\n${context}\n\n${prompt}"
    data=$(jq -n --arg p "$full_prompt" '{
        "model": "'"$MODEL"'",
        "prompt": $p,
        "stream": false,
        "temperature": 0.1,
        "top_p": 0.1
    }')

    time_operation "Ollama query for: $prompt" \
        curl -s "${LLM_API_URL}/api/generate" -d "$data" | \
        jq -r '.response' | \
        tee >(printf "${COLOR_RESPONSE}%s${COLOR_RESET}\n" "$(cat -)" >&2) | \
        sed -e '/./s/^/--| /' -e '/^$/s/^/--|/'
    
    printf "\n" >&2
)

# Store files in array
mapfile -d $'\0' files < <(find src -name "$FILE_PATTERN" -print0)

script_start=$(date +%s)

# Process each file
for file in "${files[@]}"; do
    printf "\n${COLOR_HEADER}Processing: %s${COLOR_RESET}\n" "$file" >&2
    printf "%s\n" "========================================" >&2
    time_operation "Processing $file" generate_comment "$file"
done

script_end=$(date +%s)
total_duration=$((script_end - script_start))
readable_total_duration=$(date -u -d "@${total_duration}" +"%H:%M:%S")
echo "Finished processing ${#files[@]} PureScript files in ${readable_total_duration}" >&2
